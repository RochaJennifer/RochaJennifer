/******************************************************************************

Escreva um programa que imprima todos os nC:meros pares do intervalo fechado de 1 a
100.

*******************************************************************************/
#include <stdio.h>

int
main() {
	int n = 1;

	while(n <= 100) {

		if( n % 2 == 0) {

			printf("\n%d", n);

		}
		n = n + 1;
	}

}
